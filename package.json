{
  "name": "occur2dwc",
  "version": "0.1.0",
  "description": "CLI robusto para conversão e validação de dados de ocorrência para Darwin Core (DwC).",
  "license": "MIT",
  "author": "Vicente Calfo <vicentecalfo@jbrj.gov.br>",
  "homepage": "https://github.com/Occur2DWC/occur2dwc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Occur2DWC/occur2dwc.git"
  },
  "bugs": {
    "url": "https://github.com/Occur2DWC/occur2dwc/issues"
  },
  "keywords": [
    "darwin-core",
    "dwc",
    "biodiversity",
    "cli",
    "typescript",
    "validation",
    "conversion"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "occur2dwc": "dist/cli.js"
  },
  "files": [
    "dist",
    "mapping.example.yml",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage",
    "build": "tsup",
    "dev": "tsx src/cli.ts --help",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "npm run build && c8 node scripts/coverage-runner.cjs",
    "lint-staged": "lint-staged",
    "prepare": "husky",
    "check": "npm run lint && npm run typecheck && npm run test:run && npm run build",
    "prepublishOnly": "npm run check"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "commander": "^14.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "c8": "^10.1.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.0.8"
  }
}
